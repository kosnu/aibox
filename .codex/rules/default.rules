prefix_rule(pattern=["bash", "scripts/setup-codex.sh"], decision="allow")

prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["git", "commit", "-m"], decision="allow")
prefix_rule(pattern=["git", "fetch", "origin", "main"], decision="allow")
prefix_rule(pattern=["git", "ls-remote"], decision="allow")
prefix_rule(pattern=["git", "push"], decision="allow")
prefix_rule(pattern=["git", "restore"], decision="allow")
prefix_rule(pattern=["git", "rm", "-r", "--cached"], decision="allow")
prefix_rule(pattern=["git", "stash"], decision="allow")
prefix_rule(pattern=["git", "switch"], decision="allow")

prefix_rule(pattern=["gh", "api"], decision="allow")
prefix_rule(pattern=["gh", "auth", "status"], decision="allow")
prefix_rule(pattern=["gh", "extension", "install", "github/gh-aw"], decision="allow")
prefix_rule(pattern=["gh", "issue", "comment"], decision="allow")
prefix_rule(pattern=["gh", "issue", "create"], decision="allow")
prefix_rule(pattern=["gh", "issue", "list"], decision="allow")
prefix_rule(pattern=["gh", "issue", "view"], decision="allow")
prefix_rule(pattern=["gh", "pr", "checks"], decision="allow")
prefix_rule(pattern=["gh", "pr", "create"], decision="allow")
prefix_rule(pattern=["gh", "pr", "edit"], decision="allow")
prefix_rule(pattern=["gh", "pr", "list"], decision="allow")
prefix_rule(pattern=["gh", "pr", "view"], decision="allow")
prefix_rule(pattern=["gh", "project", "list"], decision="allow")
prefix_rule(pattern=["gh", "run", "download"], decision="allow")
prefix_rule(pattern=["gh", "run", "view"], decision="allow")
